          "id": "EqUPqRSiiMZmCOTE",
          "name": "Bearer Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const zeroShotItems = $input.all();\nconst sentimentItems = $('Extract Sentiment').all();\n\nconst out = [];\n\nfor (let i = 0; i < zeroShotItems.length; i += 3) {\n  const top = zeroShotItems[i].json;\n  const originalIndex = Math.floor(i / 3);\n  const sentiment = sentimentItems[originalIndex].json;\n\n  out.push({\n    json: {\n      ...sentiment,\n      zeroshot_label: top.label,\n      zeroshot_score: Number(Number(top.score).toFixed(3))\n    }\n  });\n}\n\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -80,
        -112
      ],
      "id": "c9fcf9a8-9d2c-48fc-920e-7727326a9f31",
      "name": "Keep Top Zero Shot"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://router.huggingface.co/hf-inference/models/dslim/bert-large-NER",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"inputs\": \"{{ $json.input_text }}\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        32,
        16
      ],
      "id": "74559090-8530-48e2-8a33-d91d0dd0e0df",
      "name": "HF NER",
      "alwaysOutputData": true,
      "credentials": {
        "httpBearerAuth": {
          "id": "EqUPqRSiiMZmCOTE",
          "name": "Bearer Auth account"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const previousItems = $('Keep Top Zero Shot').all();\nconst nerItems = $input.all();\n\nconst out = previousItems.map((item) => ({\n  json: {\n    ...item.json,\n    ner_entities: \"No entities found\"\n  }\n}));\n\nfor (const item of nerItems) {\n  const pairedIndex =\n    item.pairedItem?.item ??\n    item.pairedItem?.[0]?.item ??\n    0;\n\n  const entity = item.json.word || item.json.entity_group || item.json.entity || \"unknown\";\n  const type = item.json.entity_group || item.json.entity || \"ENTITY\";\n  const score = item.json.score ? Number(item.json.score).toFixed(3) : \"n/a\";\n\n  const text = `${entity} (${type}, ${score})`;\n\n  if (out[pairedIndex]) {\n    if (out[pairedIndex].json.ner_entities === \"No entities found\") {\n      out[pairedIndex].json.ner_entities = text;\n    } else {\n      out[pairedIndex].json.ner_entities += \"; \" + text;\n    }\n  }\n}\n\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        144,

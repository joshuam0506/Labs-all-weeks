        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a fraud analyst. Classify the transaction risk as: CRITICAL, HIGH, MEDIUM, LOW, or ROUTINE. Reply with the severity level and one sentence of reasoning.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.input_text }}\"\n    }\n  ],\n  \"temperature\": 0.2,\n  \"max_tokens\": 100\n}",
        "options": {}
